# LaTeX build output (generated by latexmk into build/)
build/

# Local-only build config. Overleaf executes any committed .latexmkrc, and a
# custom $out_dir there breaks Overleaf's PDF preview — so keep it out of the repo.
.latexmkrc

# Local editor settings — not needed on Overleaf.
.vscode/

# Stray LaTeX intermediate files, in case a build runs without -output-directory
*.aux
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.log
*.out
*.toc
*.synctex.gz

# Generated PDF (the paper is built into build/ — figures use .jpg, not .pdf).
# If you ever add a PDF figure that must be tracked, force it: git add -f path.pdf
*.pdf
